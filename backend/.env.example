# Copy this file to .env and fill in real values for local development.

ENVIRONMENT=local
DEBUG=true

# SQLite by default — no setup needed. For Postgres later, use something like:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/athlyt
DATABASE_URL=sqlite:///./athlyt.db

# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-value-before-running

CORS_ORIGINS=http://localhost:3000
