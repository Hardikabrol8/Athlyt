# Copy this file to .env and fill in real values for local development.
# Production values go in the deployment platform's environment variables UI
# (Render / Railway / Fly.io) — never commit a real .env file.

# ── General ────────────────────────────────────────────────────────────────
ENVIRONMENT=local
DEBUG=true

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (local dev — no setup required):
DATABASE_URL=sqlite:///./athlyt.db

# PostgreSQL (production — uncomment and fill in):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/athlyt
#
# For managed providers:
# Render:   postgresql+psycopg2://user:pass@dpg-xxx.oregon-postgres.render.com/athlyt
# Railway:  postgresql+psycopg2://postgres:pass@containers-us-west-xxx.railway.app:6543/railway
# Supabase: postgresql+psycopg2://postgres:pass@db.xxxx.supabase.co:5432/postgres
# Neon:     postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/athlyt

# ── Auth / JWT ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-value-before-running

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:
CORS_ORIGINS=http://localhost:3000
# Production (add your Vercel URL):
# CORS_ORIGINS=https://athlyt.vercel.app,https://your-custom-domain.com

# ── ML ────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=../ml/models/workout_recommender.joblib
