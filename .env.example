# Root .env.example — used by docker-compose.yml
# Copy to .env and fill in real values before running docker compose up.
#
# Each service also has its own .env.example:
#   backend/.env.example  — for running the backend directly without Docker

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Password for the Postgres container. Used by both the postgres service
# and the backend's DATABASE_URL (auto-assembled by docker-compose.yml).
POSTGRES_PASSWORD=change-this-password

# ── Backend ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# Required — generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars

# Comma-separated. In production: your deployed frontend URL.
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at image build time.
# In production: your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
